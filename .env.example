# configuration options for hermes-otel, add one of the following configuration blocks to ~/.hermes/.env
# =============================================================================
# OPEN TELEMETRY
# =============================================================================

# Phoenix
# OTEL_PHOENIX_ENDPOINT=http://localhost:6006/v1/traces
# OTEL_PROJECT_NAME=hermes-agent

# Langfuse
# OTEL_LANGFUSE_ENDPOINT=http://localhost:3000/api/public/otel/v1/traces
# OTEL_LANGFUSE_SECRET_API_KEY=sk-lf-abcd1234-abcd-abcd-abcd-abcd1234
# OTEL_LANGFUSE_PUBLIC_API_KEY=pk-lf-abcd1234-abcd-abcd-abcd-abcd1234

# Langsmith
# LANGSMITH_API_KEY=lsv2_pt_abcdefghij1234567890_a1234567890
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_PROJECT="hermes-langsmith-otel"

# SigNoz (self-hosted — see docker-compose/signoz/README.md for the stack)
# OTEL_SIGNOZ_ENDPOINT=http://localhost:4328/v1/traces
# OTEL_PROJECT_NAME=hermes-agent

# SigNoz Cloud
# OTEL_SIGNOZ_ENDPOINT=https://ingest.us.signoz.cloud:443/v1/traces
# OTEL_SIGNOZ_INGESTION_KEY=sz-ingestion-key-abcd1234